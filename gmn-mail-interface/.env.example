# --- Core ---
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8080
# Generalo con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-me-with-a-long-random-string

# DB: sqlite di default; puoi puntare a Postgres/MySQL.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/mail

# Solo questi indirizzi possono autenticarsi (lista JSON). Vuoto = nessuna restrizione.
ALLOWED_EMAILS=["tuo.indirizzo@example.com"]

# --- SMTP per invio magic link ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_STARTTLS=true

# --- Google OAuth (opzionale) ---
# Crea credenziali su https://console.cloud.google.com (OAuth 2.0 Client ID, Web app)
# Authorized redirect URI: $APP_URL/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- IMAP ingester (opzionale) ---
# Per Gmail: usa un'App Password (https://myaccount.google.com/apppasswords)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_POLL_SECONDS=120
